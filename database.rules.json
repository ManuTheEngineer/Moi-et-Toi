{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "couples": {
      "$coupleId": {
        ".read": "root.child('couples/' + $coupleId + '/members/partner1').val() === auth.uid || root.child('couples/' + $coupleId + '/members/partner2').val() === auth.uid",
        ".write": "root.child('couples/' + $coupleId + '/members/partner1').val() === auth.uid || root.child('couples/' + $coupleId + '/members/partner2').val() === auth.uid || (auth != null && !data.exists())",
        "members": {
          ".read": "auth != null && (root.child('couples/' + $coupleId + '/members/partner1').val() === auth.uid || root.child('couples/' + $coupleId + '/members/partner2').val() === auth.uid || root.child('users/' + auth.uid + '/pendingJoin').val() === $coupleId)",
          ".validate": "newData.hasChildren(['partner1'])",
          "partner1": {
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "partner2": {
            ".write": "auth != null && (data.val() === null || data.val() === auth.uid)",
            ".validate": "newData.isString() && newData.val().length > 0"
          },
          "$other": { ".validate": false }
        },
        "status": {
          ".write": "(root.child('couples/' + $coupleId + '/members/partner1').val() === auth.uid || root.child('couples/' + $coupleId + '/members/partner2').val() === auth.uid) && newData.val() === 'active'",
          ".validate": "newData.val() === 'pending' || newData.val() === 'active'"
        },
        "inviteCode": {
          ".read": "auth != null"
        },
        "moods": { ".indexOn": ["timestamp", "date", "user"] },
        "letters": { ".indexOn": ["timestamp", "from"] },
        "taps": { ".indexOn": ["timestamp"] },
        "analytics": {
          "usage": { ".indexOn": ["timestamp"] }
        }
      }
    },
    "invites": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === auth.uid || root.child('couples/' + data.child('coupleId').val() + '/members/partner1').val() === auth.uid || root.child('couples/' + data.child('coupleId').val() + '/members/partner2').val() === auth.uid)"
      }
    },
    "config": {
      ".read": "auth != null",
      ".write": false,
      "emailMap": {
        ".write": "auth != null"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
