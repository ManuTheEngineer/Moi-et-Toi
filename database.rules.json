{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "couples": {
      "$coupleId": {
        ".read": "root.child('couples/' + $coupleId + '/members/partner1').val() === auth.uid || root.child('couples/' + $coupleId + '/members/partner2').val() === auth.uid",
        ".write": "root.child('couples/' + $coupleId + '/members/partner1').val() === auth.uid || root.child('couples/' + $coupleId + '/members/partner2').val() === auth.uid || (auth != null && !data.exists())",
        "members": {
          ".read": "auth != null",
          "partner2": {
            ".write": "auth != null && (data.val() === null || data.val() === auth.uid)"
          }
        },
        "status": {
          ".write": "auth != null && newData.val() === 'active'"
        },
        "inviteCode": {
          ".read": "auth != null"
        },
        "moods": { ".indexOn": ["timestamp", "date", "user"] },
        "letters": { ".indexOn": ["timestamp", "from"] },
        "taps": { ".indexOn": ["timestamp"] },
        "analytics": {
          "usage": { ".indexOn": ["timestamp"] }
        }
      }
    },
    "invites": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "config": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "settings": {
      ".read": "auth != null",
      ".write": false
    },
    "notifications": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
